{
    // General Bar Settings
    "layer": "top",       // Display bar above or below windows (top/bottom)
    "position": "top",    // Bar position (top/bottom/left/right)
    "height": 34,         // Height in pixels (delete for auto height)
    "spacing": 4,         // Gaps between modules in pixels

    // Choose the modules and layout placement
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "battery",
        "clock",
        "tray"
    ],

    // --- Module Configurations ---

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "´äá",
            "2": "´ëĘ",
            "3": "´äí",
            "4": "´ć╝",
            "5": "´üÁ",
            "urgent": "´ü¬",
            "focused": "´ćĺ",
            "default": "´äĹ"
        }
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true
    },

    "clock": {
        "timezone": "auto",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    "cpu": {
        "format": "´őŤ  {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "´âë  {}%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "´Śž  {capacity}%",
        "format-plugged": "´çŽ  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },

    "network": {
        "format-wifi": "´çź  {essid} ({signalStrength}%)",
        "format-ethernet": "´×ľ  {ipaddr}/{cidr}",
        "tooltip-format": "´×ľ  {ifname} via {gwaddr}",
        "format-disconnected": "ÔÜá  Disconnected"
    },

    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon}  {volume}% {format_source}",
        "format-bluetooth": "{icon}´Őö  {volume}% {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę  {format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    }
}
